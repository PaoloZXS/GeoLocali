{
  "name": "Locali",
  "short_name": "Locali",
  "description": "Esplora e condividi i migliori locali intorno a te con geolocalizzazione e mappe interattive",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen"],
  "orientation": "portrait-primary",
  "theme_color": "#1976D2",
  "background_color": "#FFFFFF",
  "icons": [
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-540x720.png",
      "sizes": "540x720",
      "type": "image/png"
    },
    {
      "src": "/screenshots/screenshot-1080x1440.png",
      "sizes": "1080x1440",
      "type": "image/png"
    }
  ],
  "categories": ["maps", "travel", "lifestyle"],
  "shortcuts": [
    {
      "name": "Nuova posizione",
      "short_name": "Aggiungi",
      "description": "Aggiungi una nuova posizione",
      "url": "/insert",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Admin",
      "short_name": "Admin",
      "description": "Pannello amministrativo",
      "url": "/admin",
      "icons": [
        {
          "src": "/icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/insert",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "photos",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
