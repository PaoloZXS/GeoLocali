{
  "buildCommand": "npm install",
  "outputDirectory": "geolocate-app/public",
  "devCommand": "npm run dev",
  "env": {
    "DB_URL": "@db_url",
    "DB_TOKEN": "@db_token",
    "JWT_SECRET": "@jwt_secret",
    "DROPBOX_APP_KEY": "@dropbox_app_key",
    "DROPBOX_APP_SECRET": "@dropbox_app_secret"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
